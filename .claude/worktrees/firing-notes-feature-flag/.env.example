# Server
PORT=8080
BASE_URL=http://localhost:8080

# Database (required)
# Local Postgres: postgresql://clay:dev-only@localhost:5432/clay
# Docker network: postgresql://clay:dev-only@clay-pg:5432/clay
DATABASE_URL=postgresql://clay:dev-only@localhost:5432/clay

# Admin credentials (basic auth)
ADMIN_USER=admin
ADMIN_PASS=changeme

# Session secret (random string, min 32 chars)
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# SMTP settings for order emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
ORDER_EMAIL=xavpaice@gmail.com
